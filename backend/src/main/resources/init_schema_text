/* Run this script in Azure Data Studio
   to manually create the empty database.
*/

USE master;
GO

-- Check if database exists, if not, create it
IF NOT EXISTS (SELECT name FROM sys.databases WHERE name = N'event-ease-db')
BEGIN
    CREATE DATABASE [event-ease-db];
    PRINT 'Database [event-ease-db] created successfully.';
END
ELSE
BEGIN
    PRINT 'Database [event-ease-db] already exists.';
END
GO

